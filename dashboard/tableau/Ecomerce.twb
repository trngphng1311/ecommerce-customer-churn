      <aliases enabled='yes' />
      <column caption='Age Band' datatype='string' name='[Calculation_5304393772675072]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// age_band&#10;IF [age] &lt; 25 THEN &quot;18-25&quot;&#10;ELSEIF [age] &lt; 35 THEN &quot;25-35&quot;&#10;ELSEIF [age] &lt; 50 THEN &quot;35-50&quot;&#10;ELSEIF [age] &lt; 65 THEN &quot;50-65&quot;&#10;ELSE &quot;65+&quot;&#10;END' />
      </column>
      <column caption='Tenure Band' datatype='string' name='[Calculation_5304393772961793]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// tenbure-band&#10;IF [tenure_months] &lt; 6 THEN &quot;0-6mo&quot;&#10;ELSEIF [tenure_months] &lt; 12 THEN &quot;6-12mo&quot;&#10;ELSEIF [tenure_months] &lt; 24 THEN &quot;1-2yr&quot;&#10;ELSE &quot;2yr+&quot;&#10;END' />
      </column>
      <column caption='Recency Band' datatype='string' name='[Calculation_5304393799680002]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// recency_band&#10;IF [last_purchase_days_ago] &lt; 30 THEN &quot;0-30d&quot;&#10;ELSEIF [last_purchase_days_ago] &lt; 90 THEN &quot;30-90d&quot;&#10;ELSEIF [last_purchase_days_ago] &lt; 180 THEN &quot;90-180d&quot;&#10;ELSE &quot;180d+&quot;&#10;END' />
      </column>
      <column caption='Support Tickets Band' datatype='string' name='[Calculation_5304393799905283]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// ticket_band&#10;IF [support_tickets] = 0 THEN &quot;0&quot;&#10;ELSEIF [support_tickets] &lt;= 3 THEN &quot;1-3&quot;&#10;ELSEIF [support_tickets] &lt;= 10 THEN &quot;4-10&quot;&#10;ELSE &quot;10+&quot;&#10;END' />
      </column>
      <column caption='Calculation-totalrevenue' datatype='integer' name='[Calculation_5304393800540164]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// total_revenue (derived)&#10;[avg_order_value] * [total_orders]' />
      </column>
      <column caption='Is Dormant Label?' datatype='string' name='[Calculation_5304393800736773]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// is_dormant_label&#10;IF [last_purchase_days_ago] &gt; 180 THEN &quot;Dormant&quot; ELSE &quot;Active&quot; END' />
      </column>
      <column caption='Calculation-ChurnRate' datatype='real' name='[Calculation_5304393802530822]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([churn_actual])' />
      </column>
      <column caption='Calculation-ChurnLabel' datatype='string' name='[Calculation_5304393811386375]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Churn Labeling&#10;IF [churn_actual] = 1 THEN &quot;Churned&quot;&#10;ELSE &quot;Retained&quot;&#10;END' />
      </column>
      <column caption='Churn Probability (bin)' datatype='integer' name='[Churn Probability (bin)]' role='dimension' type='ordinal'>
        <calculation class='bin' decimals='-2' formula='[churn_probability]' peg='0' size='0.05' />
      </column>
